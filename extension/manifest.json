{
  "manifest_version": 3,
  "name": "Lev.Charity QA",
  "version": "0.1.3",
  "description": "Record clicks, typing and assertions on lev.charity and turn them into replayable QA tests.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lev.Charity QA"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["selector.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
