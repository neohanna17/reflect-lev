rules_version = '2';

// Reflect-LEV Firestore security rules.
//
// Access model: a user may read/write app data only if they are a "member".
// Membership = a document at members/{uid} exists. Seed your first member in
// the Firebase console (Firestore > members > add document, id = your uid).
// The Playwright runner uses the Admin SDK (service account), which bypasses
// these rules entirely, so it can always write run results.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/members/$(request.auth.uid));
    }

    // "Owner" = a member whose member doc has owner: true. Set this once in the
    // Firebase console on your own members/{uid} doc. Gates owner-only actions.
    function isOwner() {
      return isMember()
        && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.owner == true;
    }

    // A reusable component whose name looks like a login flow (matches the
    // app's isLoginComponentName: contains "log in"/"login"/"sign in"/"signin",
    // optionally hyphenated). Deleting it would break every test that logs in.
    function isLoginComponent() {
      return resource.data.name is string
        && resource.data.name.lower().matches('.*(log|sign)[ \\-]*in.*');
    }

    // Membership directory. Read so the app can confirm access; managed by
    // admins in the console (or a trusted backend), never by clients.
    match /members/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Test cases (recorded by the extension, edited in the dashboard).
    match /tests/{testId} {
      allow read, create, update, delete: if isMember();
    }

    // Test run results. Members can enqueue (create) and read; the runner
    // updates them via Admin SDK.
    match /runs/{runId} {
      allow read, create, update, delete: if isMember();
    }

    // Suites = grouped tests with an optional schedule.
    match /suites/{suiteId} {
      allow read, create, update, delete: if isMember();
    }

    // Reusable components = named step sequences shared across tests. Any
    // member can read/create/edit; but the Log in component may only be DELETED
    // by an owner, so it can't be removed out from under every test.
    match /components/{componentId} {
      allow read, create, update: if isMember();
      allow delete: if isMember() && (!isLoginComponent() || isOwner());
    }

    // Feature feedback = notes / requests members leave for the admin.
    match /feedback/{feedbackId} {
      allow read, create, update, delete: if isMember();
    }

    // QA Plan task statuses = one doc per plan task (in testing / bugs found /
    // passed). Public read so the shared read-only QA Plan link (/share/qa-plan)
    // works without login; only members may change a status.
    match /qaStatus/{taskId} {
      allow read: if true;
      allow create, update, delete: if isMember();
    }

    // Presence = "who's online" heartbeats. Anyone signed in as a member can
    // see who else is active, but you may only write/clear your own doc.
    match /presence/{uid} {
      allow read: if isMember();
      allow create, update, delete: if isMember() && request.auth.uid == uid;
    }
  }
}
