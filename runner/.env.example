# Service account JSON (Firebase console > Project settings > Service accounts >
# Generate new private key). Paste the whole JSON on one line, or base64 it.
FIREBASE_SERVICE_ACCOUNT=

# Storage bucket for screenshots (usually <project-id>.appspot.com).
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_PROJECT_ID=your-project

# Leave empty to drain all queued runs; set to execute one specific run.
RUN_ID=
